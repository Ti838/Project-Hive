{
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": "public",
  "installCommand": "echo 'No dependencies to install for static site'",
  "framework": null,
  "regions": ["sin1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/assets/.*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/pages/:path*", "destination": "/pages/:path*.html" },
    { "source": "/:path((?!api|assets|pages).*)", "destination": "/:path.html" }
  ],
  "redirects": [
    { "source": "/login", "destination": "/pages/auth/login.html", "permanent": false },
    { "source": "/register", "destination": "/pages/auth/register.html", "permanent": false },
    { "source": "/dashboard", "destination": "/pages/user/dashboard.html", "permanent": false }
  ]
}
