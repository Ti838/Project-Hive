{
  "buildCommand": "echo 'Static site'",
  "outputDirectory": "public",
  "installCommand": "echo 'No install needed'",
  "framework": null,
  "regions": ["sin1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/assets/js/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/css/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/images/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/assets/svg/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/login",         "destination": "/pages/auth/login.html" },
    { "source": "/register",      "destination": "/pages/auth/register.html" },
    { "source": "/dashboard",     "destination": "/pages/user/dashboard.html" },
    { "source": "/feed",          "destination": "/pages/user/feed.html" },
    { "source": "/messages",      "destination": "/pages/user/messages.html" },
    { "source": "/notifications", "destination": "/pages/user/notifications.html" },
    { "source": "/people",        "destination": "/pages/user/people.html" },
    { "source": "/teams",         "destination": "/pages/user/teams.html" },
    { "source": "/profile",       "destination": "/pages/user/profile/edit.html" },
    { "source": "/settings",      "destination": "/pages/user/settings.html" },
    { "source": "/showcase",      "destination": "/pages/user/projects/showcase.html" },
    { "source": "/generator",     "destination": "/pages/user/projects/generator.html" },
    { "source": "/admin",         "destination": "/pages/admin/login.html" },
    { "source": "/admin/dashboard", "destination": "/pages/admin/dashboard.html" }
  ]
}
