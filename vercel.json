{
  "rewrites": [
    { "source": "/dashboard", "destination": "/pages/user/dashboard.html" },
    { "source": "/login", "destination": "/pages/auth/login.html" },
    { "source": "/register", "destination": "/pages/auth/register.html" },
    { "source": "/auth/callback", "destination": "/pages/auth/callback.html" },
    { "source": "/feed", "destination": "/pages/user/feed.html" },
    { "source": "/messages", "destination": "/pages/user/messages.html" },
    { "source": "/profile", "destination": "/pages/user/profile.html" },
    { "source": "/showcase", "destination": "/pages/user/showcase.html" },
    { "source": "/generator", "destination": "/pages/user/generator.html" },
    { "source": "/people", "destination": "/pages/user/people.html" },
    { "source": "/teams", "destination": "/pages/user/teams.html" },
    { "source": "/notifications", "destination": "/pages/user/notifications.html" },
    { "source": "/help", "destination": "/pages/info/help.html" },
    { "source": "/about", "destination": "/pages/info/about.html" },
    { "source": "/admin/login", "destination": "/pages/admin/login.html" },
    { "source": "/admin/dashboard", "destination": "/pages/admin/dashboard.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
