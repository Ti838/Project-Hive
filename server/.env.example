# ─── ProjectHive Backend — Environment ──────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=projecthive-dev-secret-change-in-production
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── Groq AI (FREE — No credit card needed) ──────────────────────────────────
# 1. Go to: https://console.groq.com
# 2. Sign up with Google or Email (FREE)
# 3. Click "API Keys" → "Create API Key"
# 4. Paste the key below (starts with gsk_...)
GROQ_API_KEY=your_groq_api_key_here

# ─── Frontend URLs (for CORS) ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
FRONTEND_URL_PROD=https://your-app.vercel.app

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
