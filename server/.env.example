# ─── ProjectHive Backend — Environment Template ───────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── Email — Brevo HTTP API ───────────────────────────────────────────────────
# 1. Go to: https://app.brevo.com → Sign up FREE (no credit card)
# 2. Profile (top-right) → SMTP & API → API Keys tab
# 3. Click "Create a new API key" → name it "ProjectHive" → Generate
# 4. Copy the key and paste below
BREVO_API_KEY=your_brevo_api_key_here
# 5. Use any email you own (must be added as sender in Brevo)
BREVO_FROM_EMAIL=your@email.com

# ─── Google Gemini AI (FREE) ─────────────────────────────────────────────────
# 1. Go to: https://aistudio.google.com/apikey
# 2. Sign in with Gmail (FREE, no credit card)
# 3. Click "Create API key"
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Frontend URLs (for CORS) ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5000
FRONTEND_URL_PROD=https://your-app.vercel.app

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
