# Environment Configuration for ProjectHive Backend

# Server
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/projecthive

# Redis (for Socket.IO adapter)
REDIS_URL=redis://:password@host:6379

# JWT Keys (generate with: openssl genrsa 2048 and openssl rsa -in private.pem -pubout)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# NVIDIA NIM API
NVIDIA_NIM_API_KEY=your_nvidia_key_here
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Cloudinary
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_KEY=your_api_key
CLOUDINARY_SECRET=your_api_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
FRONTEND_URL_PROD=https://projecthive.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
